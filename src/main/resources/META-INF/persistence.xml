<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="gestione-trasporto-pubblico-pu">
        <class>acetomartina.entities.Abbonamento</class>
        <class>acetomartina.entities.Biglietto</class>
        <class>acetomartina.entities.Mezzo</class>
        <class>acetomartina.entities.PuntoEmissione</class>
        <class>acetomartina.entities.Tessera</class>
        <class>acetomartina.entities.TitoloViaggio</class>
        <class>acetomartina.entities.Tratta</class>
        <class>acetomartina.entities.Utente</class>
        <class>acetomartina.entities.Corsa</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/gestione_trasporto_pubblico"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>